<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro | Clube do Livro</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --paper: #fdfcf0; /* Tom de papel de alta gramatura */
            --ink: #1a1a1a;
            --accent: #1e3a8a; /* Azul clássico de encadernação */
            --border: #d1d5db;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* O "Livro" de Registro */
        .register-card {
            background-color: var(--paper);
            width: 100%;
            max-width: 450px;
            padding: 40px;
            border-radius: 4px 12px 12px 4px;
            box-shadow: 20px 20px 60px rgba(0,0,0,0.1);
            border-left: 15px solid var(--accent); /* A "Lombada" */
            position: relative;
        }

        header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 1px double var(--border);
            padding-bottom: 20px;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            color: var(--ink);
            margin-bottom: 5px;
        }

        .tagline {
            font-size: 0.75rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Campos do Formulário */
        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--accent);
            margin-bottom: 6px;
        }

        input, select {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--border);
            background-color: rgba(255, 255, 255, 0.5);
            border-radius: 4px;
            font-size: 0.95rem;
            outline: none;
            transition: 0.2s;
        }

        input:focus {
            border-color: var(--accent);
            background-color: white;
        }

        /* Botão Estilizado */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: var(--accent);
            color: white;
            border: none;
            border-radius: 4px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: #1a2e6b;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(30, 58, 138, 0.2);
        }

        .footer {
            margin-top: 25px;
            text-align: center;
            font-size: 0.85rem;
            color: #4b5563;
        }

        .footer a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        /* Pequeno detalhe decorativo */
        .corner-detail {
            position: absolute;
            bottom: 10px;
            right: 15px;
            font-size: 1.2rem;
            opacity: 0.2;
        }
    </style>
</head>
<body>

    <div class="register-card">
        <header>
            <h1>Novo Capítulo</h1>
            <p class="tagline">Registre-se na nossa sociedade</p>
        </header>

        <form action="#">
            <div class="form-group">
                <label for="name">NOME COMPLETO</label>
                <input type="text" id="name" placeholder="Como devemos chamá-lo?" required>
            </div>

            <div class="form-group">
                <label for="email">ENDEREÇO DE E-MAIL</label>
                <input type="email" id="email" placeholder="seu@email.com" required>
            </div>

            <div class="form-group">
                <label for="genre">GÊNERO FAVORITO</label>
                <select id="genre">
                    <option value="ficcao">Ficção Científica</option>
                    <option value="classicos">Clássicos Literários</option>
                    <option value="biografia">Biografias</option>
                    <option value="fantasia">Fantasia</option>
                    <option value="outro">Outros</option>
                </select>
            </div>

            <div class="form-group">
                <label for="password">CRIAR SENHA</label>
                <input type="password" id="password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-submit">INICIAR JORNADA</button>
        </form>

        <div class="footer">
            <p>Já possui um registro? <a href="#">Faça Login</a></p>
        </div>

        <div class="corner-detail">🪶</div>
    </div>

</body>
</html>
