<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu de Livros</title>
    <style>
        /* Reset básico e fonte */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background-color: #f4f1ea; /* Tom de papel antigo */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .book-container {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        /* Estilo do Card/Livro */
        .book-link {
            text-decoration: none;
            color: white;
            width: 150px;
            height: 220px;
            background-color: #2c3e50;
            border-radius: 5px 15px 15px 5px; /* Curva que lembra a lombada */
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 15px;
            box-shadow: 5px 5px 15px rgba(0,0,0,0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-left: 8px solid rgba(0,0,0,0.1); /* Detalhe da lombada */
        }

        /* Efeito ao passar o mouse */
        .book-link:hover {
            transform: translateY(-10px) rotate(-3deg);
            box-shadow: 10px 15px 25px rgba(0,0,0,0.3);
            background-color: #34495e;
        }

        /* Cores diferentes para cada "livro" */
        .book-link.blue { background-color: #2980b9; }
        .book-link.red { background-color: #c0392b; }
        .book-link.green { background-color: #27ae60; }

    </style>
</head>
<body>

    <div class="book-container">
        <a href="https://google.com" target="_blank" class="book-link blue">
            <strong>O Pequeno Príncipe</strong>
        </a>

        <a href="https://wikipedia.org" target="_blank" class="book-link red">
            <strong>Dom Casmurro</strong>
        </a>

        <a href="#" class="book-link green">
            <strong>1984 - Orwell</strong>
        </a>
    </div>

</body>
</html>